{
  "name": "@model-action-protocol/core",
  "version": "0.1.0",
  "description": "MAP (Model Action Protocol) — Cryptographic provenance, self-healing, and state rollback for autonomous AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sqlite": {
      "import": "./dist/adapters/sqlite.js",
      "types": "./dist/adapters/sqlite.d.ts"
    },
    "./postgres": {
      "import": "./dist/adapters/postgres.js",
      "types": "./dist/adapters/postgres.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "keywords": [
    "ai",
    "agents",
    "provenance",
    "rollback",
    "trust",
    "safety",
    "map-protocol"
  ],
  "author": "deadpxl <neil@deadpxl.studio>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NDave27/ModelActionProtocol.git"
  },
  "homepage": "https://github.com/NDave27/ModelActionProtocol",
  "dependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.11.11",
    "better-sqlite3": "^12.8.0",
    "pg": "^8.13.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "ai": ">=6.0.0",
    "better-sqlite3": "^11.0.0 || ^12.0.0",
    "pg": "^8.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
